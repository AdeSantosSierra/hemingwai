# ===============================
# HemingwAI environment template
# ===============================
# No secrets here. Fill values in your local .env.

# --- Core providers ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
PERPLEXITY_API_KEY=
PERPLEXITY_BASE_URL=https://api.perplexity.ai

# --- MongoDB (preferred names) ---
MONGO_READ_URI=
MONGO_WRITE_URI=
MONGO_DB_NAME=Base_de_datos_noticias
MONGO_COLLECTION_NAME=Noticias
MONGO_SERVER_API_VERSION=1
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000

# --- MongoDB legacy aliases (optional fallback compatibility) ---
OLD_MONGODB_URI=
NEW_MONGODB_URI=
MONGODB_URI=

# --- Pipeline metadata ---
GIT_SHA=pipeline.local-dev

# --- Models ---
OPENAI_MODEL_MAIN=gpt-4o
OPENAI_MODEL_EMBEDDING=text-embedding-3-small
# Preferred name:
ANTHROPIC_MODEL_MAIN=claude-3-haiku-20240307
# Alias legacy-compatible:
ANTHROPIC_MODEL=claude-3-haiku-20240307
ALERT_EXTRACTOR_MODEL=gpt-4o-mini
PERPLEXITY_MODEL_FACT_CHECK=sonar-deep-research

# --- Alert thresholds ---
ALERT_MIN_BODY_CHARS=400
ALERT_MAX_ITEMS=8

# --- Timeouts/retries ---
OPENAI_TIMEOUT_SECONDS=60
OPENAI_RETRIES=3
OPENAI_RETRY_BASE_SECONDS=1
PERPLEXITY_TIMEOUT_SECONDS=120
PERPLEXITY_MAX_TOKENS=1000
PERPLEXITY_RETRIES=2
PERPLEXITY_RETRY_BASE_SECONDS=2
PATH_SUBPROCESS_TIMEOUT_SECONDS=0
LATEX_BUILD_TIMEOUT=60

# --- Feature flags ---
# false keeps current strict behavior
FEATURE_ENABLE_ANTHROPIC=true
FEATURE_FAIL_OPEN_ANTHROPIC=false
FEATURE_ENABLE_PERPLEXITY=true
FEATURE_FAIL_OPEN_PERPLEXITY=false

# --- Paths ---
PATH_VENV_DIR=.venv
PATH_OUTPUT_DIR=output_temporal
# Usually derived automatically from PATH_OUTPUT_DIR
PATH_RETRIEVED_FILE=output_temporal/retrieved_news_item.txt

# --- Logging ---
LOG_LEVEL=INFO

# --- PDF publishing (render_latex.py) ---
MEGA_EMAIL=
MEGA_PASSWORD=

# --- Optional test toggles for render_latex.py ---
RENDER_LATEX_TEST_UNICODE=
RENDER_LATEX_TEST_URL=
RENDER_LATEX_TEST_FORMAT=
